# Copy to .env (gitignored) and fill in.

# Hugging Face
HF_TOKEN=
HF_HOME=./.hf_cache

# Base model — any HuggingFace model ID or local path.
# Examples:
#   Qwen/Qwen3.6-27B                          (default; SSM hybrid VLM)
#   meta-llama/Llama-3.1-8B-Instruct
#   mistralai/Mistral-7B-Instruct-v0.3
BASE_MODEL=Qwen/Qwen3.6-27B

# Experiment tracking (optional)
WANDB_API_KEY=
WANDB_PROJECT=pslab-finetuning

# Paths
DATA_DIR=./data
MODELS_DIR=./models

# llama.cpp (for GGUF export, if not using Unsloth's built-in exporter)
LLAMA_CPP_DIR=./llama.cpp
