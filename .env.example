# Copy to .env (gitignored) and fill in.

# Hugging Face
HF_TOKEN=
HF_HOME=./.hf_cache

# Base model — VERIFY the exact repo id from the Qwen3.6-27B model card.
BASE_MODEL=Qwen/Qwen3.6-27B
# If a separate base (non-instruct) checkpoint exists, prefer it for CPT, e.g.:
# BASE_MODEL=Qwen/Qwen3.6-27B-Base

# Experiment tracking (optional)
WANDB_API_KEY=
WANDB_PROJECT=qwen-pl

# Paths
DATA_DIR=./data
MODELS_DIR=./models

# llama.cpp (for GGUF export, if not using Unsloth's built-in exporter)
LLAMA_CPP_DIR=./llama.cpp
